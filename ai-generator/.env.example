# AI Generator Configuration (copy to .env)
RELAYER_URL=http://localhost:3001

# DeepSeek V4 API (https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Generation settings
MODE=random              # "random" | "llm" | "hybrid"
INTERVAL_MS=800          # Delay between intents (ms)
BATCH_BURST=5            # Number of intents per burst (for batch demo)
STRATEGY=weighted         # "weighted" | "momentum" | "arbitrage" | "dca"
